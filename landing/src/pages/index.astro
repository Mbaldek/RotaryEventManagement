        data-de-desc="Reichen Sie Ihr Startup zur Ausgabe 2027 ein. Vorauswahl durch ein Rotary-Komitee, Pitch vor einer Fachjury, Preise zu gewinnen."
        data-en-cta="Submit my application"
        data-de-cta="Bewerbung einreichen"
      >
        <svg class="rsa-cta-card-ico" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
