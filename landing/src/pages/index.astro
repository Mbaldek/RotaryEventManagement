  <div class="rsa-lang-tg">
    <button data-l="fr" class="act">FR</button>
    <button data-l="en">EN</button>
    <button data-l="de">DE</button>
  </div>

  <script>
    // Accordion sessions (palmarès qualificatif)
    document.querySelectorAll(".rsa-acc-h").forEach((h) => {
      h.addEventListener("click", () => {
        h.parentElement?.classList.toggle("open");
      });
    });

    // ─── i18n FR/EN/DE switch ───
    // Snapshot FR au mount pour pouvoir restaurer (les textes FR sont la version
    // par défaut du DOM, on les sauve dans data-fr-{slot} la première fois).
    // Slots gérés :
    //   - nav-link  : .rsa-nav-link-label (data-en / data-de sur le <a> parent)
    //   - banner    : .rsa-banner-tag-label / .rsa-banner-title / .rsa-banner-cta-label
    //                 (data-{en|de}-tag / -title / -cta sur le <a class="rsa-banner-2027">)
    //   - cta head  : .rsa-cta-kicker (data-en / data-de), h2.rsa-cta-h-1 / .rsa-cta-h-2
    //                 (data-en-1/-2 / data-de-1/-2 sur le <h2>), .rsa-cta-lede
    //   - cta cards : .rsa-cta-card-tag / -tit / -desc / -arr-label
    //                 (data-{en|de}-tag / -tit / -desc / -cta sur le <a.rsa-cta-card>)
    function applyLang(lang) {
      const setText = (el, val) => { if (el && val != null) el.textContent = val; };

      // Helper : pour chaque [container], lit container.dataset[`${lang}${suffix}`]
      // (ou data-fr-{slot} si lang=fr) et écrit dans le sélecteur enfant.
      // Snapshot FR à la 1re utilisation pour pouvoir restaurer.
      const swap = (container, suffix, childSelector) => {
        if (!container) return;
        const child = container.querySelector(childSelector);
        if (!child) return;
        const frKey = `fr${suffix}`;
        if (!container.dataset[frKey]) container.dataset[frKey] = child.textContent;
        const value = lang === "fr"
          ? container.dataset[frKey]
          : container.dataset[`${lang}${suffix}`];
        setText(child, value);
      };

      // Nav link
      document.querySelectorAll(".rsa-nav-link").forEach((a) =>
        swap(a, "", ".rsa-nav-link-label")
      );

      // Banner 2027
      document.querySelectorAll(".rsa-banner-2027").forEach((a) => {
        swap(a, "Tag",   ".rsa-banner-tag-label");
        swap(a, "Title", ".rsa-banner-title");
        swap(a, "Cta",   ".rsa-banner-cta-label");
      });

      // CTA head
      document.querySelectorAll(".rsa-cta-kicker").forEach((el) =>
        swap(el.parentElement, "Kicker", ".rsa-cta-kicker")
      );
      document.querySelectorAll(".rsa-cta-sec h2").forEach((h2) => {
        const h1el = h2.querySelector(".rsa-cta-h-1");
        const h2el = h2.querySelector(".rsa-cta-h-2");
        if (h1el && !h2.dataset.fr1) h2.dataset.fr1 = h1el.textContent;
        if (h2el && !h2.dataset.fr2) h2.dataset.fr2 = h2el.textContent;
        setText(h1el, lang === "fr" ? h2.dataset.fr1 : h2.dataset[`${lang}1`]);
        setText(h2el, lang === "fr" ? h2.dataset.fr2 : h2.dataset[`${lang}2`]);
      });
      document.querySelectorAll(".rsa-cta-lede").forEach((p) => {
        if (!p.dataset.fr) p.dataset.fr = p.textContent.trim();
        setText(p, lang === "fr" ? p.dataset.fr : p.dataset[lang]);
      });

      // CTA cards
      document.querySelectorAll(".rsa-cta-card").forEach((a) => {
        swap(a, "Tag",  ".rsa-cta-card-tag");
        swap(a, "Tit",  ".rsa-cta-card-tit");
        swap(a, "Desc", ".rsa-cta-card-desc");
        swap(a, "Cta",  ".rsa-cta-card-arr-label");
      });

      document.documentElement.setAttribute("lang", lang);
    }

    document.querySelectorAll(".rsa-lang-tg button").forEach((b) => {
      b.addEventListener("click", () => {
        document.querySelectorAll(".rsa-lang-tg button").forEach((x) => x.classList.remove("act"));
        b.classList.add("act");
        const lang = b.getAttribute("data-l") || "fr";
        applyLang(lang);
      });
    });
  </script>
</Layout>
