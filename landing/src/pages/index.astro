      <span class="rsa-banner-tag">
        <span class="rsa-banner-tag-label">Édition 2027</span>
      </span>
      <span class="rsa-banner-title">Candidatures bientôt ouvertes</span>
      <span class="rsa-banner-cta">
        <span class="rsa-banner-cta-label">Découvrir les portes</span>
        <span class="rsa-banner-cta-arr" aria-hidden="true">→</span>
      </span>
    </span>
  </a>

  <section id="palmares" class="rsa-section">
    <div class="rsa-wrap">
      <div class="rsa-kicker">Grande Finale — 26 mai 2026</div>
      <h2>Le palmarès<br /><em>et les scores</em></h2>
      <div class="rsa-rule"></div>

      <table class="rsa-score-table">
        <thead>
          <tr>
            <th class="num">Rang</th>
            <th>Startup</th>
            <th class="num">Score/5</th>
            <th class="num">Jurés</th>
          </tr>
        </thead>
        <tbody>
          {results.map((r) => (
            <tr>
              <td>
                <div class={`rsa-score-rank${r.gold ? " gold" : ""}`}>
                  {r.medal}
                </div>
              </td>
              <td>
                <div class="rsa-score-name">{r.name}</div>
                <div class="rsa-score-sector" set:html={r.sectorHtml} />
                <div class="rsa-score-bar-wrap">
                  <div class="rsa-score-bar" style={`width:${r.barWidth}`}></div>
                </div>
              </td>
              <td><div class="rsa-score-val">{r.score}</div></td>
              <td><div class="rsa-score-jurors">{r.jurors}</div></td>
            </tr>
