      {sessions.map((s) => (
        <div class="rsa-acc">
          <button class="rsa-acc-h" type="button">
            <span class="rsa-acc-emo">{s.emoji}</span>
            <span class="rsa-acc-tit">
              {s.theme}<small>{s.date}</small>
            </span>
            <span class="rsa-acc-win">🥇 {s.winner}</span>
            <span class="rsa-acc-arr">▼</span>
          </button>
          <div class="rsa-acc-body">
            <ol class="rsa-acc-list">
              {s.ranking.map((startup, idx) => (
                <li>
                  <span class={`rsa-acc-rk${idx === 0 ? " gold" : ""}`}>
                    {idx === 0 ? "🥇" : idx + 1}
                  </span>
                  <span class="rsa-acc-nm">{startup.name}</span>
                  {startup.finalist && (
                    <span class="rsa-acc-tag">→ Finaliste</span>
                  )}
                </li>
              ))}
            </ol>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="rsa-section rsa-section-alt">
    <div class="rsa-wrap">
      <div class="rsa-kicker">Remerciements</div>
      <h2>Une édition<br /><em>rendue possible ensemble</em></h2>
